# ── Copy to .env — never commit .env itself ──────────────────────────────────

ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=console

# ── News API ──────────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
ALPHA_VANTAGE_KEY=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_NEWS_TOPIC=financial-news-raw
KAFKA_SENTIMENT_TOPIC=financial-sentiment
KAFKA_DEAD_LETTER_TOPIC=financial-dlq
KAFKA_CONSUMER_GROUP=pulsede-sentiment-cg
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ── TimescaleDB ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pulsede
DB_USER=pulsede
DB_PASSWORD=pulsede

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── ML ────────────────────────────────────────────────────────────────────────
ML_DEVICE=cpu
ML_BATCH_SIZE=16
ML_MAX_LENGTH=512
ML_TEMPERATURE=1.0
ML_MC_DROPOUT_PASSES=10
ML_UNCERTAINTY_THRESHOLD=0.15

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=pulsede-sentiment

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_PORT=8080
API_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_RATE_LIMIT_PER_MINUTE=60

# ── Monitoring ────────────────────────────────────────────────────────────────
MONITORING_PSI_THRESHOLD=0.2
MONITORING_DRIFT_CHECK_INTERVAL_SECONDS=3600
